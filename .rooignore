# 1. Thư mục hệ thống & thư viện (Khổng lồ, tuyệt đối cấm AI tự đọc)
node_modules/
.git/

# 2. Thư mục build của Svelte (Code đã biên dịch, không có giá trị phân tích)
.svelte-kit/
build/
dist/

